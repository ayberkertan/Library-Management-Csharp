<UserControl x:Class="Kutuphane.App.Views.ReturnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <materialDesign:Card Padding="16">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Kitabı İade Al" Command="{Binding ReturnBookCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,12,0"
                        Background="{StaticResource LibraryPrimaryBrush}" BorderBrush="{StaticResource LibraryPrimaryBrush}" />
                <Button Content="Listeyi Yenile" Command="{Binding LoadLoansCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />
            </StackPanel>
            <TextBlock DockPanel.Dock="Top" Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,0,0,8"
                       Foreground="{Binding IsError, Converter={StaticResource BoolToBrushConverter}}" />
            <TextBlock DockPanel.Dock="Top" Text="Yalnızca ödünçte olan kitaplar listelenir."
                       Foreground="#64748B" FontSize="12" Margin="0,0,0,8" />
            <DataGrid ItemsSource="{Binding ActiveLoans}" SelectedItem="{Binding SelectedLoan}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Kullanıcı" Binding="{Binding KullaniciAdi}" Width="*" />
                    <DataGridTextColumn Header="Kitap" Binding="{Binding KitapAdi}" Width="*" />
                    <DataGridTextColumn Header="Alış" Binding="{Binding AlisTarihi, StringFormat=d}" Width="100" />
                    <DataGridTextColumn Header="Son tarih" Binding="{Binding SonTarih, StringFormat=d}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </materialDesign:Card>
</UserControl>
