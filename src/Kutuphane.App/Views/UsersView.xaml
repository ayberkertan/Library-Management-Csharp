<UserControl x:Class="Kutuphane.App.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Padding="16" Margin="0,0,12,0">
            <StackPanel>
                <TextBlock Text="Kullanıcı Formu" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"
                           Foreground="{StaticResource LibraryPrimaryBrush}" />
                <TextBox materialDesign:HintAssist.Hint="Ad" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Ad, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <TextBox materialDesign:HintAssist.Hint="Soyad" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Soyad, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <TextBox materialDesign:HintAssist.Hint="TC (11 hane)" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Tc, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <TextBox materialDesign:HintAssist.Hint="Telefon" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Tel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <TextBox materialDesign:HintAssist.Hint="E-posta" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Mail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <ComboBox materialDesign:HintAssist.Hint="Cinsiyet"
                          SelectedValue="{Binding Cinsiyet}" SelectedValuePath="Content"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,8">
                    <ComboBoxItem Content="E" />
                    <ComboBoxItem Content="K" />
                </ComboBox>
                <TextBox materialDesign:HintAssist.Hint="Ceza (TL)" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Ceza, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                <WrapPanel>
                    <Button Content="Ekle" Command="{Binding AddUserCommand}" Margin="0,0,8,8"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource LibraryPrimaryBrush}" BorderBrush="{StaticResource LibraryPrimaryBrush}" />
                    <Button Content="Güncelle" Command="{Binding UpdateUserCommand}" Margin="0,0,8,8"
                            Style="{StaticResource MaterialDesignOutlinedButton}" />
                    <Button Content="Sil" Command="{Binding DeleteUserCommand}" Margin="0,0,8,8"
                            Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#DC2626" />
                    <Button Content="Temizle" Command="{Binding ClearFormCommandCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}" />
                </WrapPanel>
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,8,0,0"
                           Foreground="{Binding IsError, Converter={StaticResource BoolToBrushConverter}, FallbackValue=#16A34A}" />
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="1" Padding="8">
            <DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      materialDesign:DataGridAssist.CellPadding="12,8"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ad" Binding="{Binding Ad}" Width="*" />
                    <DataGridTextColumn Header="Soyad" Binding="{Binding Soyad}" Width="*" />
                    <DataGridTextColumn Header="TC" Binding="{Binding Tc}" Width="100" />
                    <DataGridTextColumn Header="Tel" Binding="{Binding Tel}" Width="110" />
                    <DataGridTextColumn Header="Ceza" Binding="{Binding Ceza, StringFormat=N2}" Width="70" />
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>
