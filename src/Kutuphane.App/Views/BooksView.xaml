<UserControl x:Class="Kutuphane.App.Views.BooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Padding="16" Margin="0,0,12,0">
            <StackPanel>
                <TextBlock Text="Kaynak Formu" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"
                           Foreground="{StaticResource LibraryPrimaryBrush}" />
                <TextBox materialDesign:HintAssist.Hint="Kitap adı" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Ad, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <TextBox materialDesign:HintAssist.Hint="Yazar" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Yazar, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <TextBox materialDesign:HintAssist.Hint="Yayıncı" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Yayinci, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <TextBox materialDesign:HintAssist.Hint="Sayfa sayısı" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding SayfaSayisi, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <DatePicker materialDesign:HintAssist.Hint="Basım tarihi"
                            SelectedDate="{Binding BasimTarihi}" Margin="0,0,0,12"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />
                <WrapPanel>
                    <Button Content="Ekle" Command="{Binding AddBookCommand}" Margin="0,0,8,8"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource LibraryPrimaryBrush}" BorderBrush="{StaticResource LibraryPrimaryBrush}" />
                    <Button Content="Güncelle" Command="{Binding UpdateBookCommand}" Margin="0,0,8,8"
                            Style="{StaticResource MaterialDesignOutlinedButton}" />
                    <Button Content="Sil" Command="{Binding DeleteBookCommand}" Margin="0,0,8,8"
                            Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#DC2626" />
                    <Button Content="Temizle" Command="{Binding ClearFormCommandCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}" />
                </WrapPanel>
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,8,0,0"
                           Foreground="{Binding IsError, Converter={StaticResource BoolToBrushConverter}}" />
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="1" Padding="8">
            <DataGrid ItemsSource="{Binding Books}" SelectedItem="{Binding SelectedBook}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ad" Binding="{Binding Ad}" Width="2*" />
                    <DataGridTextColumn Header="Yazar" Binding="{Binding Yazar}" Width="*" />
                    <DataGridTextColumn Header="Yayıncı" Binding="{Binding Yayinci}" Width="*" />
                    <DataGridTextColumn Header="Sayfa" Binding="{Binding SayfaSayisi}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>
