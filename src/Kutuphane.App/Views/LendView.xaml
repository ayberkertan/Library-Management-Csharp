<UserControl x:Class="Kutuphane.App.Views.LendView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0" Padding="16" Margin="0,0,0,12">
            <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Kullanıcı (TC)" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Ara" Command="{Binding SearchUserCommand}" Margin="8,0,0,0"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource LibraryAccentBrush}" BorderBrush="{StaticResource LibraryAccentBrush}" />
                        <TextBox materialDesign:HintAssist.Hint="TC kimlik no"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Tc, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                    <TextBlock Text="{Binding FoundUserText}" Margin="0,8,0,0"
                               Foreground="{Binding UserFound, Converter={StaticResource BoolToBrushConverter}}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Kitap ara" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBox materialDesign:HintAssist.Hint="Kitap adı"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGrid ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedBook}"
                              Height="120" Margin="0,8,0,0" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kitap" Binding="{Binding Ad}" Width="*" />
                            <DataGridTextColumn Header="Yazar" Binding="{Binding Yazar}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
                <Button Grid.Column="2" Content="Ödünç Ver" Command="{Binding LendBookCommand}" VerticalAlignment="Bottom"
                        Style="{StaticResource MaterialDesignRaisedButton}" Height="44" Padding="24,0"
                        Background="{StaticResource LibraryPrimaryBrush}" BorderBrush="{StaticResource LibraryPrimaryBrush}" />
            </Grid>
            <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,0" TextWrapping="Wrap"
                       Foreground="{Binding IsError, Converter={StaticResource BoolToBrushConverter}}" />
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="1" Padding="8">
            <DockPanel>
                <Button DockPanel.Dock="Top" Content="Listeyi Yenile" Command="{Binding LoadLoansCommand}"
                        HorizontalAlignment="Left" Margin="0,0,0,8"
                        Style="{StaticResource MaterialDesignFlatButton}" />
                <DataGrid ItemsSource="{Binding Loans}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kullanıcı" Binding="{Binding KullaniciAdi}" Width="*" />
                        <DataGridTextColumn Header="Kitap" Binding="{Binding KitapAdi}" Width="*" />
                        <DataGridTextColumn Header="Alış" Binding="{Binding AlisTarihi, StringFormat=d}" Width="90" />
                        <DataGridTextColumn Header="İade" Binding="{Binding SonTarih, StringFormat=d}" Width="90" />
                        <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding Durum}" Width="60" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
