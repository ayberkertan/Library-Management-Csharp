<Window x:Class="Kutuphane.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Kütüphane Otomasyonu"
        Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource LibrarySurfaceBrush}"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource LibrarySidebarBrush}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="16,24,16,16">
                    <materialDesign:PackIcon Kind="Bookshelf" Width="36" Height="36" Foreground="{StaticResource LibraryPrimaryLightBrush}" />
                    <TextBlock Text="Kütüphane" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <TextBlock Text="Yönetim Paneli" Foreground="#94A3B8" FontSize="12" />
                </StackPanel>

                <StackPanel Margin="4,8,4,16">
                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding ShowUsersCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountGroup" Width="22" Height="22" Foreground="White" VerticalAlignment="Center" />
                            <TextBlock Text="Kullanıcılar" Foreground="White" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding ShowBooksCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BookOpenPageVariant" Width="22" Height="22" Foreground="White" VerticalAlignment="Center" />
                            <TextBlock Text="Kaynaklar" Foreground="White" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding ShowLendCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BookPlus" Width="22" Height="22" Foreground="White" VerticalAlignment="Center" />
                            <TextBlock Text="Ödünç Ver" Foreground="White" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding ShowReturnCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BookCheck" Width="22" Height="22" Foreground="White" VerticalAlignment="Center" />
                            <TextBlock Text="Geri Al" Foreground="White" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <TextBlock Text="{Binding PageTitle}" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource LibraryPrimaryBrush}"
                           VerticalAlignment="Center" Margin="24,0" />
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}" Margin="16" />
        </Grid>
    </Grid>
</Window>
